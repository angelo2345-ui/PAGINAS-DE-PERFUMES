{
  "version": 2,
  "builds": [
    {
      "src": "arome-luxury-perfume-experience-main/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "arome-luxury-perfume-experience-main/dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
